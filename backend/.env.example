# ============================================================
# VEGAH Compliance Intelligence — Backend Environment Variables
# Copy this file to .env and fill in your actual values
# ============================================================

# --- LLM: Anthropic (Primary Reasoning + Validator + Action) ---
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- LLM: OpenAI (GPT-4o Toggle + text-embedding-3-small) ---
OPENAI_API_KEY=your_openai_api_key_here

# --- LLM: Groq (Intake + Extraction: llama-3.3-70b-versatile) ---
GROQ_API_KEY=your_groq_api_key_here

# --- Vector DB: Qdrant Cloud ---
QDRANT_URL=https://your-cluster-id.us-east4-0.gcp.cloud.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key_here

# --- Application Settings ---
APP_NAME="VEGAH Compliance Intelligence"
APP_VERSION="1.0.0"
DEBUG=true

# --- Collection Names ---
CAPABILITIES_COLLECTION=vegah_capabilities
PROPOSALS_COLLECTION=vegah_proposals

# --- Model Configuration ---
# Options: "claude" | "openai"
DEFAULT_REASONING_MODEL=claude

GROQ_MODEL=llama-3.3-70b-versatile
CLAUDE_MODEL=claude-3-5-sonnet-20241022
OPENAI_MODEL=gpt-4o
EMBEDDING_MODEL=text-embedding-3-small

# --- RAG Settings ---
EMBEDDING_DIMENSIONS=1536
TOP_K_RESULTS=5
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# --- CORS ---
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
